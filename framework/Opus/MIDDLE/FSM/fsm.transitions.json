{
  "contract": "OPUS_MIDDLE_FSM_TRANSITIONS_V1",
  "processor": "OPUS_MIDDLE_FSM",
  "states": ["IDLE", "INTENT_RECEIVED", "ROUTE_MATCHED", "CHECKED", "ALLOWED", "BACK_RUNNING", "RESPONSE_READY", "DENIED"],
  "transitions": [
    {"signal": "FRONT_INTENT", "from": "IDLE", "to": "INTENT_RECEIVED", "owner": "FRONT_TO_MIDDLE", "action": "capture_intent"},
    {"signal": "MATCH_ROUTE", "from": "INTENT_RECEIVED", "to": "ROUTE_MATCHED", "owner": "MIDDLE", "action": "match_route"},
    {"signal": "CHECK_PIPELINE", "from": "ROUTE_MATCHED", "to": "CHECKED", "owner": "MIDDLE", "action": "check_pipeline"},
    {"signal": "FSM_ALLOW", "from": "CHECKED", "to": "ALLOWED", "owner": "MIDDLE_FSM", "action": "allow_transition"},
    {"signal": "DISPATCH_BACK", "from": "ALLOWED", "to": "BACK_RUNNING", "owner": "BACK", "action": "execute_back_action"},
    {"signal": "BUILD_RESPONSE", "from": "BACK_RUNNING", "to": "RESPONSE_READY", "owner": "BACK_TO_MIDDLE", "action": "build_response"},
    {"signal": "FSM_DENY", "from": "CHECKED", "to": "DENIED", "owner": "MIDDLE_FSM", "action": "return_typed_error"}
  ]
}
