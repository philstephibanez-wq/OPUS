{
    "name": "logandplay/opus",
    "description": "OPUS lightweight modular framework core",
    "type": "library",
    "version": "8.1.0",
    "license": "proprietary",
    "require": {
        "php": ">=8.0"
    },
    "autoload": {
        "psr-4": {
            "Opus\\": "Opus/",
            "OpusLstsarManager\\": "packages/opus-lstsar-manager/src/"
        },
        "classmap": [
            "Opus/"
        ]
    },
    "bin": [
        "bin/opus"
    ],
    "scripts": {
        "opus": "@php bin/opus",
        "opus:create-application": "@php bin/opus create:application",
        "opus:create-site": "@php bin/opus create:site",
        "opus:owasys-create": "@php bin/opus owasys:create",
        "opus:owasys-export": "@php bin/opus owasys:export",
        "opus:add-language": "@php bin/opus add:language",
        "opus:serve-site": "@php bin/opus serve:site",
        "opus:validate-site": "@php bin/opus validate:site",
        "opus:list-routes": "@php bin/opus list:routes",
        "opus:create-page": "@php bin/opus create:page",
        "opus:create-rubric": "@php bin/opus create:rubric",
        "opus:smoke-all": "@php tools/smoke_all_opus.php",
        "opus:smoke-site-contract": "@php tools/smoke_opus_site_contract_eternal.php",
        "opus:smoke-fsm-contract": "@php tools/smoke_opus_fsm_contract.php",
        "opus:smoke-fsm-processor": "@php tools/smoke_opus_fsm_processor.php",
        "opus:smoke-fsm-site-loader": "@php tools/smoke_opus_fsm_site_loader.php",
        "opus:smoke-fsm-action-dispatcher": "@php tools/smoke_opus_fsm_action_dispatcher.php",
        "opus:smoke-fsm-transition-cli": "@php tools/smoke_opus_fsm_transition_cli.php",
        "opus:smoke-bin-fsm-transition": "@php tools/smoke_opus_bin_fsm_transition.php",
        "opus:smoke-validate-site-cli-fsm": "@php tools/smoke_opus_validate_site_cli_fsm.php",
        "owasys:auth-bootstrap": "@php tools/owasys_auth_bootstrap_local_user.php",
        "owasys:smoke-scaffold-plan": "@php tools/smoke_owasys_scaffold_plan_builder.php",
        "owasys:smoke-scaffold-writer": "@php tools/smoke_owasys_application_scaffold_writer.php",
        "owasys:smoke-application-creator": "@php tools/smoke_owasys_application_creator.php",
        "owasys:smoke-bin-opus-create": "@php tools/smoke_owasys_bin_opus_create.php",
        "owasys:smoke-application-exporter": "@php tools/smoke_owasys_application_exporter.php",
        "owasys:smoke-bin-opus-export": "@php tools/smoke_owasys_bin_opus_export.php",
        "owasys:smoke-i18n": "@php tools/smoke_owasys_i18n.php",
        "owasys:smoke-registry-sqlite": "@php tools/smoke_owasys_registry_sqlite.php",
        "owasys:smoke-runtime-context-sqlite": "@php tools/smoke_owasys_runtime_context_sqlite.php",
        "owasys:smoke-application-inspector": "@php tools/smoke_owasys_application_inspector.php",
        "owasys:smoke-structure-actions": "@php tools/smoke_owasys_structure_actions.php",
        "owasys:smoke-structure-drafts": "@php tools/smoke_owasys_structure_drafts.php",
        "owasys:smoke-structure-draft-ui": "@php tools/smoke_owasys_structure_draft_ui.php",
        "owasys:smoke-structure-draft-apply": "@php tools/smoke_owasys_structure_draft_apply.php",
        "owasys:smoke-structure-write-plan": "@php tools/smoke_owasys_structure_write_plan.php",
        "owasys:smoke-structure-draft-apply-ui-http": "@php tools/smoke_owasys_structure_draft_apply_ui_http.php",
        "owasys:smoke-registry-naming": "@php tools/smoke_owasys_registry_naming.php",
        "owasys:smoke-navigation-fsm": "@php tools/smoke_owasys_navigation_fsm.php",
        "owasys:smoke-showcase-blueprint": "@php tools/smoke_owasys_showcase_blueprint.php",
        "owasys:smoke-login-foundation": "@php tools/smoke_owasys_login_foundation.php",
        "owasys:smoke-login-password": "@php tools/smoke_owasys_login_password.php",
        "owasys:smoke-runtime-fsm": "@php tools/smoke_owasys_runtime_fsm.php",
        "owasys:smoke-runtime-fsm-http": "@php tools/smoke_owasys_runtime_fsm_http.php"
    },
    "repositories": [
        {
            "type": "path",
            "url": "packages/*",
            "options": {
                "symlink": true
            }
        }
    ],
    "extra": {
        "opus": {
            "packages_directory": "packages",
            "application_package_type": "opus-application",
            "owasys": {
                "site_id": "owasys",
                "contract": "OWASYS_STANDARD_OPUS_APPLICATION"
            }
        }
    }
}
