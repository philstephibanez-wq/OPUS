{
    "name": "logandplay/opus",
    "description": "OPUS lightweight modular framework core",
    "type": "library",
    "version": "8.1.0",
    "license": "proprietary",
    "require": {
        "php": ">=8.0"
    },
    "autoload": {
        "psr-4": {
            "Opus\\": "Opus/",
            "OpusLstsarManager\\": "packages/opus-lstsar-manager/src/"
        },
        "classmap": [
            "Opus/"
        ]
    },
    "bin": [
        "bin/opus"
    ],
    "scripts": {
        "opus": "@php bin/opus",
        "opus:create-application": "@php bin/opus create:application",
        "opus:create-site": "@php bin/opus create:site",
        "opus:owasys-create": "@php bin/opus owasys:create",
        "opus:owasys-export": "@php bin/opus owasys:export",
        "opus:add-language": "@php bin/opus add:language",
        "opus:serve-site": "@php bin/opus serve:site",
        "opus:validate-site": "@php bin/opus validate:site",
        "opus:list-routes": "@php bin/opus list:routes",
        "opus:create-page": "@php bin/opus create:page",
        "opus:create-rubric": "@php bin/opus create:rubric",
        "opus:smoke-site-contract": "@php tools/smoke_opus_site_contract_eternal.php",
        "owasys:smoke-scaffold-plan": "@php tools/smoke_owasys_scaffold_plan_builder.php",
        "owasys:smoke-scaffold-writer": "@php tools/smoke_owasys_application_scaffold_writer.php",
        "owasys:smoke-application-creator": "@php tools/smoke_owasys_application_creator.php",
        "owasys:smoke-bin-opus-create": "@php tools/smoke_owasys_bin_opus_create.php",
        "owasys:smoke-application-exporter": "@php tools/smoke_owasys_application_exporter.php",
        "owasys:smoke-bin-opus-export": "@php tools/smoke_owasys_bin_opus_export.php",
        "owasys:smoke-registry-naming": "@php tools/smoke_owasys_registry_naming.php",
        "owasys:smoke-showcase-blueprint": "@php tools/smoke_owasys_showcase_blueprint.php",
        "owasys:smoke-login-foundation": "@php tools/smoke_owasys_login_foundation.php"
    },
    "repositories": [
        {
            "type": "path",
            "url": "packages/*",
            "options": {
                "symlink": true
            }
        }
    ],
    "extra": {
        "opus": {
            "packages_directory": "packages",
            "application_package_type": "opus-application",
            "owasys": {
                "site_id": "owasys",
                "contract": "OWASYS_STANDARD_OPUS_APPLICATION"
            }
        }
    }
}
