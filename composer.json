{
    "name": "logandplay/opus",
    "description": "OPUS lightweight modular framework core",
    "type": "library",
    "version": "8.1.0",
    "license": "proprietary",
    "require": {
        "php": ">=8.0"
    },
    "autoload": {
        "psr-4": {
            "Opus\\": "Opus/",
            "OpusLstsarManager\\": "packages/opus-lstsar-manager/src/"
        },
        "classmap": [
            "Opus/"
        ]
    },
    "scripts": {
        "opus": "Opus\\Composer\\ComposerScripts::run",
        "opus:create-application": "Opus\\Composer\\ComposerScripts::run",
        "opus:create-site": "Opus\\Composer\\ComposerScripts::run",
        "opus:add-language": "Opus\\Composer\\ComposerScripts::run",
        "opus:serve-site": "Opus\\Composer\\ComposerScripts::run",
        "opus:validate-site": "Opus\\Composer\\ComposerScripts::run",
        "opus:list-routes": "Opus\\Composer\\ComposerScripts::run",
        "opus:create-page": "Opus\\Composer\\ComposerScripts::run",
        "opus:create-rubric": "Opus\\Composer\\ComposerScripts::run",
        "opus:export-site": "Opus\\Composer\\ComposerScripts::run",
        "owasys:registry-sync": "Opus\\Composer\\ComposerScripts::run",
        "owasys:registry-select": "Opus\\Composer\\ComposerScripts::run",
        "owasys:registry-clear": "Opus\\Composer\\ComposerScripts::run",
        "owasys:registry-creation-start": "Opus\\Composer\\ComposerScripts::run",
        "owasys:admin-password-change": "Opus\\Composer\\ComposerScripts::run"
    },
    "repositories": [
        {
            "type": "path",
            "url": "packages/*",
            "options": {
                "symlink": true
            }
        }
    ],
    "extra": {
        "opus": {
            "packages_directory": "packages",
            "application_package_type": "opus-application",
            "owasys": {
                "site_id": "owasys",
                "contract": "OWASYS_STANDARD_OPUS_APPLICATION"
            }
        }
    }
}
