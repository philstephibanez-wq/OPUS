{
  "name": "opus-owasys-frontend",
  "private": true,
  "version": "1.0.0",
  "description": "Reproducible local frontend assets for OWASYS.",
  "scripts": {
    "build:owasys-editor": "esbuild assets-src/owasys-codemirror-entry.js --bundle --minify --format=iife --target=es2020 --outfile=sites/owasys/www/asset/vendor/codemirror/owasys-codemirror.js",
    "build": "npm run build:owasys-editor"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/lang-javascript": "^6.2.3",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.3.2",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-sql": "^6.9.0",
    "@codemirror/language": "^6.11.0",
    "@codemirror/search": "^6.5.10",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.5"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
