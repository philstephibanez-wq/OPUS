<!doctype html>
<html lang="{{ lang }}">
<head>
  <meta charset="utf-8">
  <title>{{ title }} â€” {{ moduleTitle }}</title>
  <link rel="stylesheet" href="{{ basePath }}/assets/css/refbook.css?v=P113B8">
</head>
<body class="{{ themeClass }}">
<div class="app-shell">
  <header class="site-header" role="banner">
    <a class="site-brand" href="{{ basePath }}/?lang={{ lang }}&theme={{ theme }}" aria-label="{{ moduleTitle }}">
      <span class="site-brand-mark" aria-hidden="true">A</span>
      <span class="site-brand-copy">
        <strong>Opus <span>REFBOOK</span></strong>
        <small>{{ ui.topbar.subtitle }}</small>
      </span>
    </a>

    <div class="site-controls" aria-label="{{ ui.topbar.controls }}">
      <form class="top-search" method="get" action="{{ basePath }}/" role="search" aria-label="{{ ui.search.form_label }}">
        <input type="hidden" name="lang" value="{{ lang }}">
        <input type="hidden" name="theme" value="{{ theme }}">
        <input type="hidden" name="page" value="search">
        <label class="visually-hidden" for="refbook-search">{{ ui.search.input_label }}</label>
        <input id="refbook-search" name="q" type="search" value="{{ searchQuery }}" maxlength="96" placeholder="{{ ui.search.placeholder }}">
        <button type="submit">{{ ui.search.submit }}</button>
      </form>

      <nav class="theme-switcher segmented-switcher" aria-label="{{ ui.theme.current }}">
        {% for code in themes %}
          <a href="{{ basePath }}/?lang={{ lang }}&theme={{ code }}{% if pageSlug is not empty %}&page={{ pageSlug }}{% endif %}"
             title="{{ attribute(ui.theme, code) }}"
             data-theme="{{ code }}"
             {% if code == theme %}class="active" aria-current="true"{% endif %}>{{ attribute(ui.theme.short, code) }}</a>
        {% endfor %}
      </nav>

      <nav class="language-switcher segmented-switcher" aria-label="{{ ui.language.current }}">
        {% for code in languages %}
          <a href="{{ basePath }}/?lang={{ code }}&theme={{ theme }}{% if pageSlug is not empty %}&page={{ pageSlug }}{% endif %}"
             title="{{ attribute(ui.language, code) }}"
             hreflang="{{ code }}"
             data-language="{{ code }}"
             {% if code == lang %}class="active" aria-current="true"{% endif %}>{{ code|upper }}</a>
        {% endfor %}
      </nav>
    </div>
  </header>

  {% set isGuidePage = pageSlug|slice(0, 6) == 'guide-' %}
  {% set isDomainPage = pageSlug|slice(0, 7) == 'domain-' %}
  {% set isSearchPage = pageSlug == 'search' %}

  <div class="app-body">
    <aside class="sidebar" aria-label="{{ ui.sidebar.menu }}">
      <a class="brand{% if pageSlug is empty %} active{% endif %}" href="{{ basePath }}/?lang={{ lang }}&theme={{ theme }}">Opus RefBook</a>

      <nav class="side-nav" aria-label="{{ ui.sidebar.menu }}">
        <div class="nav-direct">
          <a href="{{ basePath }}/?lang={{ lang }}&theme={{ theme }}&page=search"{% if isSearchPage %} class="active"{% endif %}>{{ ui.sidebar.search }}</a>
          <a href="{{ basePath }}/?lang={{ lang }}&theme={{ theme }}&page=api-reference"{% if pageSlug == 'api-reference' %} class="active"{% endif %}>{{ ui.sidebar.api_reference }}</a>
        </div>

        <details class="nav-group" {% if pageSlug is empty or pageSlug == 'api-reference' or isGuidePage or isSearchPage %}open{% endif %}>
          <summary>{{ ui.sidebar.guides }} <span>{{ navigationGuides|length }}</span></summary>
          <div class="nav-list">
            {% for guide in navigationGuides %}
              <a href="{{ basePath }}/?lang={{ lang }}&theme={{ theme }}&page={{ guide.slug }}"{% if pageSlug == guide.slug %} class="active"{% endif %}>{{ guide.title }}</a>
            {% endfor %}
          </div>
        </details>

        <details class="nav-group nav-group-domains" {% if isDomainPage %}open{% endif %}>
          <summary>{{ ui.sidebar.domains }} <span>{{ navigationDomains|length }}</span></summary>
          <div class="nav-list nav-list-compact">
            {% for domain in navigationDomains %}
              <a href="{{ basePath }}/?lang={{ lang }}&theme={{ theme }}&page=domain-{{ domain.slug }}"{% if pageSlug == 'domain-' ~ domain.slug %} class="active"{% endif %}>{{ domain.name }} <span>{{ domain.count }}</span></a>
            {% endfor %}
          </div>
        </details>
      </nav>
    </aside>

    <main class="content">
      <nav class="breadcrumb" aria-label="{{ ui.breadcrumb.label }}">
        <a href="{{ basePath }}/?lang={{ lang }}&theme={{ theme }}">{{ ui.breadcrumb.home }}</a>
        {% if pageSlug is not empty %}
          <span aria-hidden="true">/</span>
          <span aria-current="page">{{ breadcrumbTitle }}</span>
        {% endif %}
      </nav>

      {% block content %}{% endblock %}
    </main>
  </div>
</div>
</body>
</html>
