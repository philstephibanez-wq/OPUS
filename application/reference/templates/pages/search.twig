{% extends 'layout.twig' %}
{% block content %}
<section class="hero compact-hero search-hero">
  <p class="kicker">{{ ui.search.kicker }}</p>
  <h1>{{ ui.search.title }}</h1>
  <p>{{ ui.search.intro }}</p>
</section>

<section class="panel search-panel">
  <form class="search-page-form" method="get" action="{{ basePath }}/" role="search" aria-label="{{ ui.search.form_label }}">
    <input type="hidden" name="lang" value="{{ lang }}">
    <input type="hidden" name="theme" value="{{ theme }}">
    <input type="hidden" name="page" value="search">
    <label for="refbook-search-page">{{ ui.search.input_label }}</label>
    <div class="search-page-row">
      <input id="refbook-search-page" name="q" type="search" value="{{ search.query }}" maxlength="96" placeholder="{{ ui.search.placeholder_long }}" autofocus>
      <button type="submit">{{ ui.search.submit }}</button>
    </div>
    <p>{{ ui.search.help }}</p>
  </form>
</section>

{% if search.has_query %}
  <section class="panel search-results-panel">
    <div class="panel-heading">
      <div>
        <p class="kicker">{{ ui.search.results_kicker }}</p>
        <h2>{{ ui.search.results_title }} <code>{{ search.query }}</code></h2>
      </div>
      <span class="pill">{{ search.count }} {{ ui.search.results }}</span>
    </div>

    {% if search.results is empty %}
      <div class="empty-state">
        <strong>{{ ui.search.empty_title }}</strong>
        <p>{{ ui.search.empty_body }}</p>
      </div>
    {% else %}
      <div class="search-results">
        {% for result in search.results %}
          <a class="search-result-card" href="{{ basePath }}/?lang={{ lang }}&theme={{ theme }}&page={{ result.page }}">
            <span class="search-result-meta">{{ result.meta }}</span>
            <strong>{{ result.title }}</strong>
            <span>{{ result.subtitle }}</span>
            <em>{{ result.snippet }}</em>
            <span class="tag-list compact-tags">
              {% for badge in result.badges %}
                <span>{{ badge }}</span>
              {% endfor %}
            </span>
          </a>
        {% endfor %}
      </div>
    {% endif %}
  </section>
{% else %}
  <section class="panel search-tips">
    <div class="panel-heading">
      <div>
        <p class="kicker">{{ ui.search.tips_kicker }}</p>
        <h2>{{ ui.search.tips_title }}</h2>
      </div>
    </div>
    <ul class="check-list">
      {% for tip in ui.search.tips %}
        <li>{{ tip }}</li>
      {% endfor %}
    </ul>
  </section>
{% endif %}
{% endblock %}
