{
    "contract": "OPUS_ACL_POLICY_REGISTRY_V1",
    "engine": "hierarchical_acl",
    "roles": {
        "visitor": {
            "parents": []
        },
        "authenticated": {
            "parents": [
                "visitor"
            ]
        },
        "staff": {
            "parents": [
                "visitor"
            ]
        },
        "developer": {
            "parents": [
                "authenticated",
                "staff"
            ]
        },
        "editor": {
            "parents": [
                "staff"
            ]
        },
        "marketing": {
            "parents": [
                "staff"
            ]
        },
        "admin": {
            "parents": [
                "authenticated"
            ]
        }
    },
    "resources": {
        "api": {
            "parent": null
        },
        "api.status": {
            "parent": "api"
        },
        "api.identity": {
            "parent": "api"
        },
        "api.security.policies": {
            "parent": "api"
        },
        "api.lstsar": {
            "parent": "api"
        },
        "api.lstsar.contracts": {
            "parent": "api.lstsar"
        },
        "api.lstsar.pipeline": {
            "parent": "api.lstsar"
        },
        "api.lstsar.engine.skeleton": {
            "parent": "api.lstsar"
        },
        "site": {
            "parent": null
        },
        "article": {
            "parent": "site"
        },
        "newsletter": {
            "parent": "site"
        },
        "admin-panel": {
            "parent": "site"
        }
    },
    "policies": {
        "api.status.view": {
            "resource": "api.status",
            "privilege": "view"
        },
        "api.identity.view": {
            "resource": "api.identity",
            "privilege": "view"
        },
        "api.security.policies.view": {
            "resource": "api.security.policies",
            "privilege": "view"
        },
        "api.lstsar.contracts.view": {
            "resource": "api.lstsar.contracts",
            "privilege": "view"
        },
        "api.lstsar.pipeline.view": {
            "resource": "api.lstsar.pipeline",
            "privilege": "view"
        },
        "api.lstsar.engine.skeleton.view": {
            "resource": "api.lstsar.engine.skeleton",
            "privilege": "view"
        },
        "acl.demo.article.read": {
            "resource": "article",
            "privilege": "read"
        },
        "acl.demo.article.publish": {
            "resource": "article",
            "privilege": "publish"
        },
        "acl.demo.article.edit": {
            "resource": "article",
            "privilege": "edit"
        },
        "acl.demo.article.archive": {
            "resource": "article",
            "privilege": "archive"
        },
        "acl.demo.newsletter.send": {
            "resource": "newsletter",
            "privilege": "send"
        },
        "acl.demo.admin-panel.delete": {
            "resource": "admin-panel",
            "privilege": "delete"
        },
        "acl.demo.admin-panel.view": {
            "resource": "admin-panel",
            "privilege": "view"
        }
    },
    "rules": [
        {
            "effect": "allow",
            "roles": [
                "visitor"
            ],
            "resources": [
                "api.status"
            ],
            "privileges": [
                "view"
            ],
            "description": "Public API status endpoint."
        },
        {
            "effect": "allow",
            "roles": [
                "authenticated"
            ],
            "resources": [
                "api.identity"
            ],
            "privileges": [
                "view"
            ],
            "description": "Any authenticated identity can inspect itself."
        },
        {
            "effect": "allow",
            "roles": [
                "admin",
                "developer"
            ],
            "resources": [
                "api.security.policies"
            ],
            "privileges": [
                "view"
            ],
            "description": "Security policy diagnostics for admin/developer roles."
        },
        {
            "effect": "allow",
            "roles": "*",
            "resources": [
                "api.security.policies"
            ],
            "privileges": [
                "view"
            ],
            "conditions": [
                {
                    "type": "scope_any",
                    "scopes": [
                        "security:read",
                        "opus:admin"
                    ]
                }
            ],
            "description": "Security policy diagnostics via security scopes."
        },
        {
            "effect": "allow",
            "roles": [
                "admin",
                "developer"
            ],
            "resources": [
                "api.lstsar.contracts",
                "api.lstsar.pipeline",
                "api.lstsar.engine.skeleton"
            ],
            "privileges": [
                "view"
            ],
            "description": "LSTSAR diagnostics for admin/developer roles."
        },
        {
            "effect": "allow",
            "roles": "*",
            "resources": [
                "api.lstsar.contracts",
                "api.lstsar.pipeline",
                "api.lstsar.engine.skeleton"
            ],
            "privileges": [
                "view"
            ],
            "conditions": [
                {
                    "type": "scope_any",
                    "scopes": [
                        "lstsar:read",
                        "lstsar:execute",
                        "opus:admin"
                    ]
                }
            ],
            "description": "LSTSAR diagnostics via LSTSAR scopes."
        },
        {
            "effect": "allow",
            "roles": [
                "visitor"
            ],
            "resources": [
                "site"
            ],
            "privileges": [
                "view"
            ],
            "description": "OPUS demo: public site view inherited by descendants."
        },
        {
            "effect": "allow",
            "roles": [
                "visitor"
            ],
            "resources": [
                "article"
            ],
            "privileges": [
                "read"
            ],
            "description": "OPUS demo: visitor can read articles."
        },
        {
            "effect": "allow",
            "roles": [
                "staff"
            ],
            "resources": [
                "article"
            ],
            "privileges": [
                "edit",
                "review"
            ],
            "description": "OPUS demo: staff gets article edit/review."
        },
        {
            "effect": "allow",
            "roles": [
                "editor"
            ],
            "resources": [
                "article"
            ],
            "privileges": [
                "publish",
                "archive"
            ],
            "description": "OPUS demo: editor gets publish/archive."
        },
        {
            "effect": "allow",
            "roles": [
                "marketing"
            ],
            "resources": [
                "newsletter"
            ],
            "privileges": [
                "send"
            ],
            "conditions": [
                {
                    "type": "claim_equals",
                    "claim": "contextIsPreview",
                    "equals": true
                }
            ],
            "description": "OPUS demo: conditional newsletter send."
        },
        {
            "effect": "allow",
            "roles": [
                "admin"
            ],
            "resources": "*",
            "privileges": "*",
            "description": "OPUS demo: admin all resources / all privileges."
        },
        {
            "effect": "deny",
            "roles": [
                "staff"
            ],
            "resources": [
                "admin-panel"
            ],
            "privileges": [
                "view"
            ],
            "description": "OPUS demo: explicit deny on admin panel."
        }
    ]
}
