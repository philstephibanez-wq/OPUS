{
    "schema": "OPUS_FSM_RUNTIME_V1",
    "id": "runtime_exception",
    "initial_state": "RUNTIME_ACTIVE",
    "final_states": [
        "EXCEPTION_TRACED"
    ],
    "transitions": [
        {
            "from": "RUNTIME_ACTIVE",
            "signal": "php.error",
            "to": "PHP_ERROR_NORMALIZED",
            "collector": "exception"
        },
        {
            "from": "PHP_ERROR_NORMALIZED",
            "signal": "exception.created",
            "to": "OPUS_EXCEPTION_READY",
            "collector": "exception"
        },
        {
            "from": "OPUS_EXCEPTION_READY",
            "signal": "profiler.recorded",
            "to": "EXCEPTION_TRACED",
            "collector": "exception"
        }
    ]
}
