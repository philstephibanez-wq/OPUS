            "fsm_signal": "route.dispatched"
        },
        {
            "id": "core.security.policies",
            "method": "GET",
            "path": "v1/security/policies",
            "endpoint": "Opus\\Api\\Endpoint\\SecurityPoliciesEndpoint",
            "acl_policy": "api.security.policies.view",
            "fsm_flow": "runtime_request",
            "fsm_signal": "route.dispatched"
        },
        {
            "id": "lstsar.contracts",
            "method": "GET",
