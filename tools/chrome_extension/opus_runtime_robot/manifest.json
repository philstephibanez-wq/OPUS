{
  "manifest_version": 3,
  "name": "Opus Runtime Robot",
  "version": "0.1.0",
  "description": "Local Opus runtime inspection helper for localhost development pages.",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "action": {
    "default_title": "Opus Runtime Robot",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://127.0.0.1/*",
        "http://localhost/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
