<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <title>Opus P116B5 live ScoreTemplate report</title>
</head>
<body style="margin:0;padding:0;font-family:Arial,Helvetica,sans-serif;color:#111827;">
<table width="100%" cellpadding="0" cellspacing="0" border="0"><tr><td align="center" style="padding:18px;">
<table width="760" cellpadding="0" cellspacing="0" border="0" style="max-width:760px;width:100%;border:1px solid #d9e2f3;">
<tr><td bgcolor="#0f2342" style="padding:20px;color:#ffffff;">
<div style="font-size:12px;letter-spacing:2px;text-transform:uppercase;color:#93c5fd;font-weight:bold;">Opus secure by design · ScoreTemplate</div>
<h1 style="margin:8px 0 6px;font-size:26px;line-height:32px;color:#ffffff;">FSM + ACL + Navigation + Formulaires</h1>
<div style="font-size:14px;color:#cbd5e1;">3 utilisateurs · FR / ES / EN · généré le {{ generated_at }}</div>
</td></tr>
<tr><td style="padding:16px;">
<p><strong>ScoreTemplate:</strong> {{ score_status }} &nbsp; <strong>Mail:</strong> {{ mail.status }} &nbsp; <strong>Default deny:</strong> observable &nbsp; <strong>POST forms:</strong> tested</p>
<p>Ce mail est généré par un template <code>.score</code>, distinct du rapport navigateur complet.</p>
<table width="100%" cellpadding="0" cellspacing="0" border="0" style="border:1px solid #d9e2f3;">
<tr bgcolor="#edf3ff"><th style="padding:8px;">User</th><th style="padding:8px;">Lang</th><th style="padding:8px;">Method</th><th style="padding:8px;">Type</th><th style="padding:8px;">Route</th><th style="padding:8px;">Expected</th><th style="padding:8px;">Observed</th><th style="padding:8px;">Result</th></tr>
[[ foreach: rows as row ]]
<tr><td style="padding:8px;border-bottom:1px solid #d9e2f3;">{{ row.label }}</td><td style="padding:8px;border-bottom:1px solid #d9e2f3;">{{ row.language|upper }}</td><td style="padding:8px;border-bottom:1px solid #d9e2f3;">{{ row.method }}</td><td style="padding:8px;border-bottom:1px solid #d9e2f3;">{{ row.kind }}</td><td style="padding:8px;border-bottom:1px solid #d9e2f3;"><code>{{ row.route }}</code></td><td style="padding:8px;border-bottom:1px solid #d9e2f3;">{{ row.expected }}</td><td style="padding:8px;border-bottom:1px solid #d9e2f3;">{{ row.observed }}</td><td style="padding:8px;border-bottom:1px solid #d9e2f3;color:{{ row.status_color }};font-weight:bold;">{{ row.status }}</td></tr>
[[ endforeach ]]
</table>
</td></tr>
</table>
</td></tr></table>
</body>
</html>
