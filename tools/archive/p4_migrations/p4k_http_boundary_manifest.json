{
  "patch_id": "P4K_MOVE_HTTP_CLASSES",
  "contract": {
    "typed_variables": true,
    "zero_hardcode": true,
    "zero_bidouille": true,
    "zero_silent_fallback": true,
    "wrappers_are_forbidden_fallbacks": true,
    "no_alias": true,
    "no_stub": true,
    "no_relay_file": true
  },
  "moves": [
    {
      "symbol": "Opus\\Request",
      "new_symbol": "Opus\\Http\\Request",
      "source": "Opus/Request.php",
      "target": "Opus/Http/Request.php"
    },
    {
      "symbol": "Opus\\Response",
      "new_symbol": "Opus\\Http\\Response",
      "source": "Opus/Response.php",
      "target": "Opus/Http/Response.php"
    }
  ],
  "runtime_call_sites": [
    "Opus/Kernel.php",
    "Opus/Router.php"
  ],
  "notes": [
    "This migration creates a real Http boundary for modern namespaced classes.",
    "It changes namespace declarations and imports instead of creating fallback wrappers.",
    "It refuses unexpected file content and refuses to overwrite existing targets."
  ]
}
