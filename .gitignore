# OPUS repository ignore rules
#
# The repository contains the OPUS framework and its sites.
# Generated dependencies, local runtime data, secrets and workstation files
# must not be versioned.

# Composer dependencies
/vendor/

# Framework frontend dependencies
/Opus/Assets/node_modules/
/Opus/Assets/npm-debug.log*
/Opus/Assets/yarn-debug.log*
/Opus/Assets/yarn-error.log*
/Opus/Assets/pnpm-debug.log*

# Local tools: not part of the OPUS product
/tools/

# Local environment and secrets
/.env
/.env.*
!/.env.example
*.local.php
*.secret.php
/runtime/owasys/backend-env.cmd

# Site runtime state
#
# Each site owns its runtime directories. Keep only the directory markers.
/sites/*/var/*
!/sites/*/var/cache/
!/sites/*/var/logs/
/sites/*/var/cache/*
!/sites/*/var/cache/.gitkeep
/sites/*/var/logs/*
!/sites/*/var/logs/.gitkeep

# Runtime databases and SQLite sidecars
*.sqlite
*.sqlite-wal
*.sqlite-shm
*.sqlite-journal

# Test, analysis and documentation caches
/.phpunit.cache/
/.phpunit.result.cache
/.phpdoc/
/.phpdoc-cache/
/.cache/
/coverage/
/tmp/

# Generic generated and temporary artifacts
*.tmp
*.temp
*.bak
*.backup
*.orig
*.rej
*.patch
*.diff
*.log

# IDE and operating-system files
/.idea/
/.vscode/
.DS_Store
Thumbs.db
Desktop.ini
