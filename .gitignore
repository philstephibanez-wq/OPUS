# Opus repository ignore rules
#
# Opus is a reusable PHP framework. The repository must not track generated
# dependencies, local secrets, runtime state, reports, caches, temporary files,
# or machine-specific artifacts.

# Dependencies
/vendor/
/composer.lock

# Local environment / secrets
/.env
/.env.*
!/.env.example
*.local.php
*.secret.php

# Documentation and tooling caches
/.phpdoc/
/.phpdoc-cache/
/.cache/
/tmp/

# Runtime state
/var/*
!/var/.gitkeep
/var/generated/
/var/lstsa/
/var/recipes/

# SQLite runtime sidecars
*.sqlite-wal
*.sqlite-shm
*.sqlite-journal

# Generic generated / temporary artifacts
*.tmp
*.temp
*.bak
*.backup
*.orig
*.rej
*.patch
*.diff
*.log

# OS / editor noise
.DS_Store
Thumbs.db
