# Opus repository ignore rules
#
# Opus is a reusable PHP framework. The repository must not track generated
# dependencies, local secrets, development state, reports, temporary files,
# or machine-specific artifacts.

# Dependencies
/vendor/
/composer.lock

# Local environment / secrets
/.env
/.env.*
!/.env.example
*.local.php
*.secret.php

# Documentation and tooling caches
/.phpdoc/
/.phpdoc-cache/
/.cache/
/tmp/

# Runtime state
#
# OPUS product runtime var contract is strict:
#   - /var/cache for runtime cache payloads
#   - /var/logs for runtime log payloads
# Nothing else belongs under /var in OPUS.
/var/*
!/var/cache/
!/var/logs/
/var/cache/*
!/var/cache/.gitkeep
/var/logs/*
!/var/logs/.gitkeep

# SQLite runtime sidecars
*.sqlite-wal
*.sqlite-shm
*.sqlite-journal

# Generic generated / temporary artifacts
*.tmp
*.temp
*.bak
*.backup
*.orig
*.rej
*.patch
*.diff
*.log

# OS / editor noise
.DS_Store
Thumbs.db
