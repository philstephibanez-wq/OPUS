<!doctype html>
<html lang="{{ lang }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ page.title }}</title>
  <link rel="stylesheet" href="/assets/css/starter.css">
</head>
<body class="opus-starter-site">
  {{ common.header }}
  <main class="opus-main" id="main-content">
    {{ content }}
  </main>
  {{ common.footer }}
</body>
</html>