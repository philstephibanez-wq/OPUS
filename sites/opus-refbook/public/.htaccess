# OPUS_REF_BOOK front-controller rewrite
# Contract:
# - expose OPUS_REF_BOOK as an Opus application under UwAmp/Apache
# - route non-existing files/directories to public/index.php
# - do not duplicate Opus framework inside OPUS_REF_BOOK
# - no fallback JSON, no silent alternate data source

Options -MultiViews
RewriteEngine On
RewriteBase /

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^ index.php [QSA,L]

