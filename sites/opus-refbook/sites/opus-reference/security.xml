<?xml version="1.0" encoding="UTF-8"?>
<security>
  <fsm initialState="request_started" requestSignal="allow_request">
    <states>
      <state id="request_started" label="Request started" />
      <state id="request_allowed" label="Request allowed" />
    </states>
    <transitions>
      <transition from="request_started" signal="allow_request" to="request_allowed" />
    </transitions>
  </fsm>

  <acl role="public" resource="refbook" privilege="view">
    <roles>
      <role id="public" />
    </roles>
    <resources>
      <resource id="refbook" />
    </resources>
    <privileges>
      <privilege id="view" />
    </privileges>
    <rules>
      <allow role="public" resource="refbook" privilege="view" />
    </rules>
  </acl>
</security>
