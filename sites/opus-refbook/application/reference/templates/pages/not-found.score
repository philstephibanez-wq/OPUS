<section class="hero compact-hero">
  <p class="kicker">{{ ui.not_found.kicker }}</p>
  <h1>{{ title }}</h1>
  <p>{{ ui.not_found.message }}: <code>{{ slug }}</code></p>
</section>

<section class="panel">
  <p>No fallback page was selected. The requested RefBook slug is unknown.</p>
  <p><a href="{{ basePath }}/?lang={{ lang }}&amp;theme={{ theme }}">Back to OPUS RefBook home</a></p>
</section>
