<section class="ow-panel ow-auth-panel"><header><span class="ow-badge">{{ labels.password_auth }}</span><h2>{{ labels.sign_in }}</h2><p>{{ labels.sign_in_description }}</p></header>[[ if: auth.error ]]<p class="ow-error">{{ auth.error }}</p>[[ endif ]]<form method="post" action="{{ urls.current }}"><input type="hidden" name="owasys_action" value="sso-authenticate"><input type="hidden" name="owasys_sso_provider" value="{{ auth.provider }}"><label>{{ labels.username }}<input name="owasys_username" autocomplete="username" required></label><label>{{ labels.password }}<input type="password" name="owasys_password" autocomplete="current-password" required></label><button type="submit">{{ labels.login }}</button></form></section>
