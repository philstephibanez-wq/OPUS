<section class="ow-panel ow-auth-panel"><header><span class="ow-badge">{{ labels.account }}</span><h2>{{ labels.change_password }}</h2><p>{{ labels.change_password_description }}</p></header>[[ if: auth.error ]]<p class="ow-error">{{ auth.error }}</p>[[ endif ]]<form method="post" action="{{ urls.current }}"><input type="hidden" name="owasys_action" value="change-password"><label>{{ labels.current_password }}<input type="password" name="owasys_current_password" required></label><label>{{ labels.new_password }}<input type="password" name="owasys_new_password" minlength="10" required></label><label>{{ labels.confirm_password }}<input type="password" name="owasys_confirm_password" minlength="10" required></label><button type="submit">{{ labels.change_password }}</button></form></section>
