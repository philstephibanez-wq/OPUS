<section class="ow-card"><header><h2>{{ labels.application_context }}</h2><p>{{ labels.select_instruction }}</p></header>[[ if: current_app.present ]]<div class="ow-tags"><span>{{ labels.id }}: {{ current_app.id }}</span><span>{{ labels.kind }}: {{ current_app.kind }}</span><span>{{ labels.root }}: {{ current_app.root }}</span></div>[[ else ]]<p>{{ labels.none_selected }}</p>[[ endif ]]</section><section class="ow-grid">[[ foreach: entries as entry ]]<article class="ow-card"><span class="ow-pill">{{ entry.status }}</span><h2>{{ entry.name }}</h2><p>{{ entry.root }}</p><form method="post" action="{{ urls.current }}"><input type="hidden" name="owasys_action" value="select-app"><input type="hidden" name="owasys_app_id" value="{{ entry.id }}"><button type="submit">{{ labels.work_on_app }}</button></form></article>[[ endforeach ]]</section>
