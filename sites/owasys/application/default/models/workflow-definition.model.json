{
    "contract": "OPUS_MODEL_SCHEMA_V1",
    "model": "owasys_workflow_definition",
    "storage": {
        "datasource": "owasys_registry",
        "access": "model_then_odbc",
        "engine": "sqlite3",
        "table": "owasys_workflows"
    },
    "fields": {
        "id": {
            "type": "string",
            "required": true,
            "max_length": 96
        },
        "application_id": {
            "type": "string",
            "required": true,
            "max_length": 64
        },
        "label": {
            "type": "string",
            "required": true,
            "max_length": 160
        },
        "states_json": {
            "type": "json",
            "required": true,
            "max_bytes": 65535
        },
        "transitions_json": {
            "type": "json",
            "required": true,
            "max_bytes": 65535
        }
    }
}
