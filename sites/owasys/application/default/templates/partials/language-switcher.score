<div class="ow-locale-switcher" data-owasys-locale-switcher><button type="button" class="ow-locale-trigger" aria-expanded="false"><img src="{{ locale.flag }}" alt=""><span>{{ locale.name }}</span></button><div class="ow-locale-menu" hidden>[[ foreach: locales as item ]]<a href="{{ item.url }}" lang="{{ item.code }}" [[ if: item.active ]]aria-current="true"[[ endif ]]><img src="{{ item.flag }}" alt=""><span>{{ item.name }}</span></a>[[ endforeach ]]</div></div>
