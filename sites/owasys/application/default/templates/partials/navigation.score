<nav class="ow-global-nav" data-context="OWASYS_GLOBAL_NAVIGATION" aria-label="{{ navigation.aria_label }}">
  [[ foreach: navigation.items as item ]]
  <a href="{{ item.href }}" class="ow-global-nav-link" [[ if: item.current ]]aria-current="page"[[ endif ]]>{{ item.label }}</a>
  [[ endforeach ]]
</nav>
