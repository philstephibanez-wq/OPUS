<nav class="ow-global-nav" aria-label="[[ i18n: navigation.main ]]">
  [[ foreach: navigation as item ]]
    [[ if: item.allowed ]]
      <a class="ow-global-nav-link[[ if: item.active ]] is-active[[ endif ]]" href="{{ item.url }}" [[ if: item.active ]]aria-current="page"[[ endif ]]>{{ item.label }}</a>
    [[ endif ]]
  [[ endforeach ]]
</nav>
