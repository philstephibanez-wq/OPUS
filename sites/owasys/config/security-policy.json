{
    "contract": "OWASYS_SECURITY_POLICY_V1",
    "profiles": {
        "admin": {
            "can": [
                "registry.create",
                "registry.update",
                "registry.delete",
                "blueprint.configure",
                "build.generate",
                "build.validate",
                "export.create"
            ]
        },
        "dev": {
            "can": [
                "registry.create_draft",
                "structure.configure",
                "data.configure",
                "workflows.configure",
                "security.configure_draft",
                "build.validate"
            ]
        }
    },
    "session_strategy": "explicit",
    "local_bootstrap": {
        "enabled": true,
        "profile": "dev",
        "route": "/login",
        "logout_route": "/logout",
        "purpose": "Local development session foundation only; production authentication and admin credentials are not committed."
    },
    "committed_passwords_allowed": false,
    "audit_strategy": "mandatory_for_write_actions"
}
