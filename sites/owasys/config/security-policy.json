{
    "contract": "OWASYS_SECURITY_POLICY_V1",
    "profiles": {
        "admin": {
            "can": [
                "registry.create",
                "registry.update",
                "registry.delete",
                "blueprint.configure",
                "build.generate",
                "build.validate",
                "export.create",
                "account.password.change"
            ]
        },
        "dev": {
            "can": [
                "registry.create_draft",
                "structure.configure",
                "data.configure",
                "workflows.configure",
                "security.configure_draft",
                "build.validate",
                "account.password.change"
            ]
        }
    },
    "session_strategy": "explicit",
    "local_credentials": {
        "enabled": true,
        "store": "var/auth/local-users.json",
        "store_contract": "OWASYS_LOCAL_USER_STORE_V1",
        "password_hash_required": true,
        "plain_text_passwords_forbidden": true,
        "committed_credentials_forbidden": true,
        "bootstrap_tool": "tools/owasys_auth_bootstrap_local_user.php",
        "must_change_password_on_bootstrap": true,
        "password_change_route": "/account/password",
        "minimum_password_length": 12
    },
    "committed_passwords_allowed": false,
    "audit_strategy": "mandatory_for_write_actions"
}
