{
  "contract": "OPUS_SITE_APPLICATION_TREE_V2",
  "site_id": "owasys",
  "site_name": "OPUS OWASYS",
  "long_name": "OPUS Web Application System",
  "role": "standard-opus-application",
  "purpose": "Registry, configuration, scaffolding, generation and validation of OPUS web applications.",
  "default_locale": "fr",
  "locales": [
    "bg",
    "hr",
    "cs",
    "da",
    "nl",
    "en",
    "et",
    "fi",
    "fr",
    "de",
    "el",
    "hu",
    "ga",
    "it",
    "lv",
    "lt",
    "mt",
    "pl",
    "pt",
    "ro",
    "sk",
    "sl",
    "es",
    "sv",
    "uk"
  ],
  "theme": "owasys",
  "public_root": "www",
  "application_root": "application",
  "default_root": "application/default",
  "asset_root": "www/asset",
  "dispatch_model": "fsm-module-first",
  "navigation": {
    "fsm": "config/owasys-navigation.fsm.json",
    "source_of_truth": "config"
  },
  "auth": {
    "session_name": "OWASYS_LOCAL_SESSION",
    "mode": "sso",
    "sso_config": "config/sso.json",
    "login_route": "/login",
    "logout_route": "/logout",
    "password_change_route": "/account/password",
    "anonymous_routes": [
      "/login"
    ],
    "protected_routes": "all_except_anonymous_routes",
    "must_change_password_on_bootstrap": true,
    "minimum_password_length": 10,
    "write_actions_require_auth": true,
    "committed_passwords_allowed": false
  },
  "i18n": {
    "contract": "OPUS_APPLICATION_I18N_POLICY_V1",
    "default_source": "browser",
    "fallback_locale": "fr",
    "catalog_format": "json",
    "supported_catalog_formats": [
      "json",
      "yaml",
      "yml",
      "xml"
    ],
    "locale_tag_style": "bcp47",
    "allow_regional_variants": true,
    "silent_fallback": false
  }
}
