  "asset_root": "www/asset",
  "dispatch_model": "fsm-module-first",
  "navigation": {
    "fsm": "config/owasys-navigation.fsm.json",
    "source_of_truth": "config"
  },
  "auth": {
    "session_name": "OWASYS_LOCAL_SESSION",
    "mode": "sso",
    "sso_config": "config/sso.json",
    "login_route": "/login",
    "logout_route": "/logout",
    "password_change_route": "/account/password",
    "anonymous_routes": [
      "/login"
    ],
    "protected_routes": "all_except_anonymous_routes",
    "must_change_password_on_bootstrap": true,
    "minimum_password_length": 10,
    "write_actions_require_auth": true,
    "committed_passwords_allowed": false
  },
  "i18n": {
    "contract": "OPUS_APPLICATION_I18N_POLICY_V4",
    "default_source": "browser",
    "fallback_locale": "fr-FR",
    "catalog_format": "json",
    "supported_catalog_formats": [
      "json",
      "yaml",
      "yml",
      "xml"
    ],
    "locale_tag_style": "bcp47",
    "allow_regional_variants": true,
    "catalogs_versioned": true,
    "regional_overlay_policy": "explicit-empty-overlay-inherits-base-language",
    "silent_fallback": false,
    "matrix": {
      "catalog_base_locales": 25,
      "selectable_regional_locales": 37,
      "total_catalog_locales": 62,
      "selector_locales": 37,
      "territories": [
        "EU",
        "CH",
        "UA"
      ]
    },
    "catalog_filename": "locale-tag",
    "catalog_filename_pattern": "<locale>.<extension>",
    "legacy_catalog_prefixes_allowed": false,
    "selectable_locales": "regional-only",
    "bare_language_policy": "map-to-default-regional-locale",
    "language_defaults": {
