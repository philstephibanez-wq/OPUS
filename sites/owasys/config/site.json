{
    "contract": "OPUS_SITE_APPLICATION_TREE_V1_ETERNAL",
    "site_id": "owasys",
    "site_name": "OPUS OWASYS",
    "long_name": "OPUS Web Application System",
    "role": "standard-opus-application",
    "purpose": "Registry, configuration, scaffolding, generation and validation of OPUS web applications.",
    "default_locale": "fr",
    "locales": [
        "bg",
        "hr",
        "cs",
        "da",
        "nl",
        "en",
        "et",
        "fi",
        "fr",
        "de",
        "el",
        "hu",
        "ga",
        "it",
        "lv",
        "lt",
        "mt",
        "pl",
        "pt",
        "ro",
        "sk",
        "sl",
        "es",
        "sv",
        "uk"
    ],
    "theme": "owasys",
    "public_root": "www",
    "application_root": "application",
    "states_root": "application/states",
    "default_root": "application/default",
    "asset_root": "www/asset",
    "theme_root_pattern": "www/asset/themes/<theme>",
    "dispatch_model": "state-first",
    "controller_field": "legacy_alias",
    "menu_items": 7,
    "states": [
        "home",
        "registry",
        "structure",
        "data",
        "workflows",
        "security",
        "build",
        "account",
        "login"
    ],
    "application_roots": [
        "default",
        "states/home",
        "states/registry",
        "states/structure",
        "states/data",
        "states/workflows",
        "states/security",
        "states/build",
        "states/account",
        "states/login"
    ],
    "src_directory_allowed": false,
    "css_inheritance": [
        "application/default/css",
        "www/asset/themes/<theme>/css",
        "application/states/<state>/css"
    ],
    "js_inheritance": [
        "application/default/javascript",
        "www/asset/themes/<theme>/js",
        "application/states/<state>/javascript"
    ],
    "owasys_stage": "fsm-driven-navigation-context",
    "navigation": {
        "fsm": "config/owasys-navigation.fsm.json",
        "source_of_truth": "config",
        "runtime_state_database": "var/registry/owasys.sqlite",
        "runtime_context_table": "owasys_runtime_context",
        "transition_history_table": "owasys_transition_history",
        "transition_drafts_table": "owasys_transition_drafts"
    },
    "registry": {
        "datasource": "owasys_registry",
        "schema": "config/registry.schema.sql",
        "seed": "config/registry.seed.json",
        "model": "application/default/models/application-registry.model.json",
        "runtime_database": "var/registry/owasys.sqlite",
        "commit_runtime_database": false
    },
    "creation": {
        "contract": "config/create-application.contract.json",
        "scaffold_plan_schema": "config/scaffold-plan.schema.json",
        "export_policy": "config/export-policy.json",
        "request_model": "application/default/models/application-request.model.json",
        "plan_model": "application/default/models/scaffold-plan.model.json",
        "runtime_execution": "explicit-command-only"
    },
    "auth": {
        "session_name": "OWASYS_LOCAL_SESSION",
        "mode": "runtime-password-store",
        "user_store": "var/auth/local-users.json",
        "login_route": "/login",
        "logout_route": "/logout",
        "password_change_route": "/account/password",
        "anonymous_routes": [
            "/login"
        ],
        "protected_routes": "all_except_anonymous_routes",
        "must_change_password_on_bootstrap": true,
        "minimum_password_length": 10,
        "write_actions_require_auth": true,
        "password_hash_algorithm": "PASSWORD_DEFAULT",
        "committed_passwords_allowed": false
    },
    "capabilities": [
        "application_registry",
        "application_blueprints",
        "application_creation_contracts",
        "scaffold_plans",
        "structure_configuration",
        "datasource_configuration",
        "workflow_configuration",
        "security_profiles",
        "build_validation",
        "export_policy",
        "runtime_password_login_foundation",
        "auth_access_guard",
        "forced_password_change",
        "fsm_driven_navigation",
        "state_first_dispatch"
    ]
}
