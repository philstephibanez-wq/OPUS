{
  "contract": "OWASYS_NAVIGATION_FSM_V1",
  "name": "OWASYS navigation FSM",
  "source_of_truth": "config",
  "initial_state": "login",
  "states": [
    {
      "id": "login",
      "module": "login",
      "requires_auth": false,
      "requires_current_app": false
    },
    {
      "id": "account",
      "module": "account",
      "requires_auth": true,
      "requires_current_app": false
    },
    {
      "id": "registry",
      "module": "registry",
      "requires_auth": true,
      "requires_current_app": false
    },
    {
      "id": "structure",
      "module": "structure",
      "requires_auth": true,
      "requires_current_app": true
    },
    {
      "id": "data",
      "module": "data",
      "requires_auth": true,
      "requires_current_app": true
    },
    {
      "id": "workflows",
      "module": "workflows",
      "requires_auth": true,
      "requires_current_app": true
    },
    {
      "id": "security",
      "module": "security",
      "requires_auth": true,
      "requires_current_app": true
    },
    {
      "id": "source",
      "module": "source",
      "requires_auth": true,
      "requires_current_app": true
    },
    {
      "id": "build",
      "module": "build",
      "requires_auth": true,
      "requires_current_app": false
    }
  ],
  "events": [
    {
      "id": "login_success"
    },
    {
      "id": "password_change_required"
    },
    {
      "id": "password_changed"
    },
    {
      "id": "select_app"
    },
    {
      "id": "change_app"
    },
    {
      "id": "clear_app_context"
    },
    {
      "id": "create_new_app"
    },
    {
      "id": "open_structure"
    },
    {
      "id": "open_data"
    },
    {
      "id": "open_workflows"
    },
    {
      "id": "open_security"
    },
    {
      "id": "open_source"
    },
    {
      "id": "open_build"
    },
    {
      "id": "logout"
    }
  ],
  "transitions": [
    {
      "id": "t_login_success_registry",
      "from": "login",
      "event": "login_success",
      "to": "registry",
      "actions": [
        "start_session"
      ]
    },
    {
      "id": "t_password_required_account",
      "from": "login",
      "event": "password_change_required",
      "to": "account",
      "guards": [
        "must_change_password"
      ],
      "actions": [
        "redirect_password_change"
      ]
    },
    {
      "id": "t_password_changed_registry",
      "from": "account",
      "event": "password_changed",
      "to": "registry",
      "actions": [
        "update_runtime_password_hash",
        "clear_must_change_password"
      ]
    },
    {
      "id": "t_select_app_structure",
      "from": "registry",
      "event": "select_app",
      "to": "structure",
      "guards": [
        "app_exists"
      ],
      "actions": [
        "set_current_app"
      ]
    },
    {
      "id": "t_create_new_build",
      "from": "registry",
      "event": "create_new_app",
      "to": "build",
      "actions": [
        "clear_current_app",
        "start_creation_flow"
      ]
    },
    {
      "id": "t_registry_structure",
      "from": "registry",
      "event": "open_structure",
      "to": "structure",
      "guards": [
        "current_app_required"
      ]
    },
    {
      "id": "t_structure_data",
      "from": "structure",
      "event": "open_data",
      "to": "data",
      "guards": [
        "current_app_required"
      ]
    },
    {
      "id": "t_data_workflows",
      "from": "data",
      "event": "open_workflows",
      "to": "workflows",
      "guards": [
        "current_app_required"
      ]
    },
    {
      "id": "t_workflows_security",
      "from": "workflows",
      "event": "open_security",
      "to": "security",
      "guards": [
        "current_app_required"
      ]
    },
    {
      "id": "t_security_source",
      "from": "security",
      "event": "open_source",
      "to": "source",
      "guards": [
        "current_app_required"
      ]
    },
    {
      "id": "t_security_build",
      "from": "security",
      "event": "open_build",
      "to": "build",
      "guards": [
        "current_app_required"
      ]
    },
    {
      "id": "t_source_build",
      "from": "source",
      "event": "open_build",
      "to": "build",
      "guards": [
        "current_app_required"
      ]
    },
    {
      "id": "t_change_app_registry",
      "from": "*",
      "event": "change_app",
      "to": "registry"
    },
    {
      "id": "t_clear_context_registry",
      "from": "registry",
      "event": "clear_app_context",
      "to": "registry",
      "actions": [
        "clear_current_app"
      ]
    },
    {
      "id": "t_logout_login",
      "from": "*",
      "event": "logout",
      "to": "login",
      "actions": [
        "clear_session",
        "clear_current_app"
      ]
    }
  ]
}
