{
    "contract": "OPUS_MODEL_SCHEMA_V1",
    "model": "owasys_application_registry",
    "storage": {
        "datasource": "owasys_registry",
        "access": "model_then_odbc",
        "engine": "sqlite3",
        "table": "owasys_applications"
    },
    "fields": {
        "id": {
            "type": "string",
            "required": true,
            "max_length": 64
        },
        "slug": {
            "type": "slug",
            "required": true,
            "max_length": 96
        },
        "name": {
            "type": "string",
            "required": true,
            "max_length": 160
        },
        "kind": {
            "type": "enum",
            "values": [
                "fullstack",
                "frontend",
                "backend",
                "package"
            ]
        },
        "root_path": {
            "type": "path",
            "required": true,
            "max_length": 260
        },
        "public_root": {
            "type": "string",
            "required": true,
            "max_length": 64
        },
        "default_locale": {
            "type": "locale",
            "required": true,
            "exact_length": 2
        },
        "theme": {
            "type": "string",
            "required": true,
            "max_length": 96
        },
        "local_url": {
            "type": "url",
            "required": false,
            "max_length": 255
        },
        "git_remote": {
            "type": "url",
            "required": false,
            "max_length": 255
        },
        "git_branch": {
            "type": "string",
            "required": false,
            "max_length": 96
        },
        "composer_package": {
            "type": "string",
            "required": false,
            "max_length": 160
        },
        "status": {
            "type": "enum",
            "values": [
                "draft",
                "configured",
                "validated",
                "generated",
                "exported",
                "archived"
            ]
        },
        "created_at": {
            "type": "datetime",
            "required": true
        },
        "updated_at": {
            "type": "datetime",
            "required": true
        }
    }
}
