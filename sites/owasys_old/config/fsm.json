{
    "contract": "OPUS_FSM_REGISTRY_V1",
    "owner": "owasys",
    "states": [
        "draft",
        "configured",
        "validated",
        "generated",
        "exported"
    ],
    "transitions": [
        {
            "from": "draft",
            "to": "configured",
            "action": "configure"
        },
        {
            "from": "configured",
            "to": "validated",
            "action": "validate"
        },
        {
            "from": "validated",
            "to": "generated",
            "action": "generate"
        },
        {
            "from": "generated",
            "to": "exported",
            "action": "export"
        }
    ]
}
