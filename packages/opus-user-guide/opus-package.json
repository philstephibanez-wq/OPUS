{
  "package_name": "OPUS_USER_GUIDE",
  "package_slug": "opus-user-guide",
  "package_type": "official_optional_guide",
  "package_status": "reserved_pending_implementation",
  "requires_opus_version": "8.1.0",
  "requires_opus_name": "OPUS Framework",
  "entrypoint": "public/index.php",
  "public_root": "public/",
  "application_root": "application/",
  "resources": {
    "score_templates": "resources/score/",
    "i18n": "resources/i18n/",
    "assets": "resources/assets/"
  },
  "core_resolution": {
    "mode": "shared_opus_core_required",
    "forbid_embedded_framework": true,
    "fail_if_core_missing": true,
    "fallback_allowed": false
  },
  "license_profile": "OPUS_SOURCE_AVAILABLE_FREE_NONCOMMERCIAL_COMMERCIAL_ROYALTIES",
  "publication_profile": {
    "offline_first": true,
    "online_publishable": true,
    "github_update_check": "explicit_user_action_only"
  },
  "clean_deliverable_gate": {
    "active_twig_templates_allowed": false,
    "legacy_backups_allowed": false,
    "dead_css_overrides_allowed": false,
    "runtime_cache_allowed": false,
    "secrets_allowed": false,
    "duplicated_framework_allowed": false
  }
}
