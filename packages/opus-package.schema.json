{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://logandplay.org/schemas/opus-package.schema.json",
  "title": "OPUS Package Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "package_name",
    "package_slug",
    "package_type",
    "package_status",
    "requires_opus_version",
    "requires_opus_name",
    "entrypoint",
    "public_root",
    "application_root",
    "resources",
    "core_resolution",
    "license_profile",
    "license",
    "publication_profile",
    "clean_deliverable_gate"
  ],
  "properties": {
    "package_name": { "type": "string", "minLength": 1 },
    "package_slug": { "type": "string", "minLength": 1 },
    "package_type": { "type": "string", "minLength": 1 },
    "package_status": { "type": "string", "minLength": 1 },
    "requires_opus_version": { "type": "string", "minLength": 1 },
    "requires_opus_name": { "const": "OPUS Framework" },
    "entrypoint": { "type": "string", "minLength": 1 },
    "public_root": { "type": "string", "minLength": 1 },
    "application_root": { "type": "string", "minLength": 1 },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["score_templates", "i18n", "assets"],
      "properties": {
        "score_templates": { "type": "string", "minLength": 1 },
        "i18n": { "type": "string", "minLength": 1 },
        "assets": { "type": "string", "minLength": 1 }
      }
    },
    "core_resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "forbid_embedded_framework", "fail_if_core_missing", "fallback_allowed"],
      "properties": {
        "mode": { "const": "shared_opus_core_required" },
        "forbid_embedded_framework": { "const": true },
        "fail_if_core_missing": { "const": true },
        "fallback_allowed": { "const": false }
      }
    },
    "license_profile": { "const": "OPUS_SOURCE_AVAILABLE_FREE_NONCOMMERCIAL_COMMERCIAL_ROYALTIES" },
    "license": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile", "copyright_holder", "free_use_scope", "commercial_use", "commercial_royalties", "osi_open_source", "legal_files_required_before_public_release"],
      "properties": {
        "profile": { "const": "OPUS_SOURCE_AVAILABLE_FREE_NONCOMMERCIAL_COMMERCIAL_ROYALTIES" },
        "copyright_holder": { "const": "Philippe Stéphane Ibanez" },
        "free_use_scope": { "type": "string", "minLength": 1 },
        "commercial_use": { "const": "paid_commercial_license_required" },
        "commercial_royalties": { "const": "required" },
        "osi_open_source": { "const": false },
        "legal_files_required_before_public_release": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "minItems": 6,
          "uniqueItems": true
        }
      }
    },
    "publication_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["offline_first", "online_publishable", "github_update_check"],
      "properties": {
        "offline_first": { "const": true },
        "online_publishable": { "type": "boolean" },
        "github_update_check": { "const": "explicit_user_action_only" }
      }
    },
    "clean_deliverable_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["active_twig_templates_allowed", "legacy_backups_allowed", "dead_css_overrides_allowed", "runtime_cache_allowed", "secrets_allowed", "duplicated_framework_allowed"],
      "properties": {
        "active_twig_templates_allowed": { "const": false },
        "legacy_backups_allowed": { "const": false },
        "dead_css_overrides_allowed": { "const": false },
        "runtime_cache_allowed": { "const": false },
        "secrets_allowed": { "const": false },
        "duplicated_framework_allowed": { "const": false }
      }
    }
  }
}
