<section class="opus-lstsar-manager opus-lstsar-manager-dry-run">
  <h1>{{ title }}</h1>
  <p>Mode: {{ mode }}</p>
  <p>Dry-run: {{ dry_run }}</p>
  <p>Engine integrated: {{ dry_run_engine_integrated }}</p>
  <p>Execution enabled: {{ execution_enabled }}</p>
  <p>Raw SQL allowed: {{ raw_sql_allowed }}</p>
  <p>DDL allowed: {{ ddl_allowed }}</p>
  <pre>{{ preview }}</pre>
</section>
