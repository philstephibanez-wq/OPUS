{
    "contract": "OPUS_APPLICATION_PACKAGE_MANIFEST_V1",
    "package": "logandplay/opus-lstsar-manager",
    "application": {
        "slug": "opus-lstsar-manager",
        "name": "OPUS LSTSAR Manager"
    },
    "paths": {
        "application": "app",
        "routes": "app/routes.php",
        "views": "templates",
        "i18n": "i18n",
        "assets": "assets",
        "config": "config",
        "acl": "config/acl.php",
        "navigation": "config/navigation.php",
        "profiler": "config/profiler.php"
    },
    "integrations": {
        "scoretemplate": true,
        "i18n": true,
        "sso_acl": true,
        "diagnostics": true,
        "profiler": true,
        "lstsar_model_driven_odbc_engine": true
    },
    "security": {
        "protected": true,
        "anonymous": false,
        "denied_by_default": true
    },
    "metadata": {
        "source": "packages",
        "composer_installable": true,
        "lstsar_manager_package_core": true,
        "lstsar_manager_dry_run_integration_core": true,
        "lstsar_manager_dashboard_operations_core": true,
        "site_client_operations_dashboard": true,
        "operation_listing_enabled": true,
        "operation_status_enabled": true,
        "mapping_assignment_coverage_enabled": true,
        "model_driven_odbc": true,
        "odbc_only": true,
        "declarative_backoffice": true,
        "dry_run_enabled": true,
        "dry_run_engine_integrated": true,
        "dry_run_uses_lstsar_model_driven_odbc_engine": true,
        "execution_enabled": false,
        "direct_execute_allowed": false,
        "manual_launch_enabled": false,
        "scheduler_launch_enabled": false,
        "raw_sql_allowed": false,
        "ddl_enabled": false,
        "profiler_instrumented": true
    }
}
